{
  "model_details": {
    "name": "Motor Insurance Risk-Based Premium System",
    "version": "3.0",
    "student_id": "IT22271600",
    "date": "2026-03-04",
    "type": "Frequency-Severity + ML Hybrid",
    "license": "Academic",
    "contact": "IT22271600@student.university.ac.lk"
  },
  "model_architecture": {
    "risk_classifier": {
      "algorithm": "HistGradientBoostingClassifier",
      "calibration": "CalibratedClassifierCV (isotonic, cv=5)",
      "pipeline": "StandardScaler \u2192 Calibrated HGBC",
      "features": [
        "Driver_Age",
        "Years_Driving_Experience",
        "Engine_CC",
        "Vehicle_Age_Years",
        "Sum_Insured_LKR",
        "Previous_NCB_Percentage",
        "Experience_Rate",
        "Age_x_Exp",
        "Is_Young_Driver",
        "Is_Senior_Driver",
        "Is_New_Driver",
        "Log_SI",
        "CC_x_VehicleAge",
        "Occupation_cat",
        "Province_cat"
      ],
      "feature_count": 15,
      "leakage_free": true
    },
    "premium_regressor": {
      "algorithm": "HistGradientBoostingRegressor",
      "pipeline": "StandardScaler \u2192 HGBR",
      "features": [
        "Proposed_Sum_Insured_LKR",
        "Risk_Score",
        "NCB_Claimed_Percentage",
        "Driver_Age",
        "Years_of_Driving_Experience",
        "Engine_CC",
        "Vehicle_Age_Years",
        "Market_Value_LKR",
        "Vehicle_Condition_ord",
        "SI_MV_Ratio",
        "Is_Young_Driver",
        "Is_Senior_Driver",
        "Log_SI",
        "Log_MV",
        "Age_x_Exp",
        "Experience_Rate",
        "CC_x_VehicleAge",
        "Is_Blacklisted",
        "Rebate_Approved",
        "Province_cat",
        "Vehicle_Type_cat",
        "Gender_cat",
        "Occupation_cat"
      ],
      "feature_count": 23
    },
    "actuarial_model": {
      "frequency_model": "Calibrated HGBC \u2192 P(Claim)",
      "severity_model": "HGBR",
      "formula": "Pure Premium = P(Claim) \u00d7 E[Severity | Claim]",
      "expected_severity_lkr": 2139428,
      "loading_factors": {
        "expense_ratio": 0.3,
        "profit_margin": 0.05,
        "stamp_duty": 0.01,
        "vat": 0.06,
        "cess": 0.005,
        "min_rate_pct": 0.015
      }
    }
  },
  "performance_metrics": {
